# AWS Cognito Configuration
# Get these values after running the Cognito setup script
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# JWT Secret (for any additional custom auth)
JWT_SECRET=your-super-secret-jwt-key-change-this

# S3 Bucket for file uploads (create this bucket in AWS)
S3_BUCKET_NAME=travel-assistant-uploads

# Bedrock Model ID (for Claude AI itinerary generation)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20260217-v1:0
