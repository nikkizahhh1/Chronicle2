    "serviceRawFile": "service: travel-assistant-backend\n\nprovider:\n  name: aws\n  runtime: python3.12\n  region: us-east-1\n  environment:\n    JWT_SECRET: ${env:JWT_SECRET}\n    COGNITO_USER_POOL_ID: ${env:COGNITO_USER_POOL_ID}\n    COGNITO_CLIENT_ID: ${env:COGNITO_CLIENT_ID}\n    S3_BUCKET_NAME: ${env:S3_BUCKET_NAME}\n    BEDROCK_MODEL_ID: ${env:BEDROCK_MODEL_ID, 'anthropic.claude-3-5-sonnet-20241022-v2:0'}\n    LOCATION_MAP_NAME: ${env:LOCATION_MAP_NAME, 'TripMapView'}\n    LOCATION_PLACE_INDEX_NAME: ${env:LOCATION_PLACE_INDEX_NAME, 'TripPlaceIndex'}\n  iam:\n    role:\n      statements:\n        - Effect: Allow\n          Action:\n            - dynamodb:Query\n            - dynamodb:Scan\n            - dynamodb:GetItem\n            - dynamodb:PutItem\n            - dynamodb:UpdateItem\n            - dynamodb:DeleteItem\n          Resource:\n            - \"arn:aws:dynamodb:${self:provider.region}:*:table/users\"\n            - \"arn:aws:dynamodb:${self:provider.region}:*:table/trips\"\n            - \"arn:aws:dynamodb:${self:provider.region}:*:table/travel-pois\"\n            - \"arn:aws:dynamodb:${self:provider.region}:*:table/*/index/*\"\n        - Effect: Allow\n          Action:\n            - cognito-idp:SignUp\n            - cognito-idp:InitiateAuth\n            - cognito-idp:ConfirmSignUp\n            - cognito-idp:ResendConfirmationCode\n            - cognito-idp:GetUser\n          Resource:\n            - \"arn:aws:cognito-idp:${self:provider.region}:*:userpool/*\"\n        - Effect: Allow\n          Action:\n            - s3:PutObject\n            - s3:GetObject\n            - s3:DeleteObject\n            - s3:PutObjectAcl\n          Resource:\n            - \"arn:aws:s3:::${env:S3_BUCKET_NAME}/*\"\n        - Effect: Allow\n          Action:\n            - bedrock:InvokeModel\n          Resource: '*'\n        - Effect: Allow\n          Action:\n            - geo:GetMapTile\n            - geo:GetMapStyleDescriptor\n            - geo:GetMapSprites\n            - geo:GetMapGlyphs\n            - geo:SearchPlaceIndexForText\n            - geo:SearchPlaceIndexForPosition\n            - geo:CalculateRoute\n          Resource:\n            - \"arn:aws:geo:${self:provider.region}:*:map/*\"\n            - \"arn:aws:geo:${self:provider.region}:*:place-index/*\"\n            - \"arn:aws:geo:${self:provider.region}:*:route-calculator/*\"\n\nfunctions:\n  signup:\n    handler: handlers/auth.signup\n    events:\n      - http:\n          path: auth/signup\n          method: post\n          cors: true\n\n  login:\n    handler: handlers/auth.login\n    events:\n      - http:\n          path: auth/login\n          method: post\n          cors: true\n\n  confirmSignup:\n    handler: handlers/auth.confirm_signup\n    events:\n      - http:\n          path: auth/confirm\n          method: post\n          cors: true\n\n  resendConfirmation:\n    handler: handlers/auth.resend_confirmation\n    events:\n      - http:\n          path: auth/resend\n          method: post\n          cors: true\n\n  submitQuiz:\n    handler: handlers/quiz.submit_quiz\n    events:\n      - http:\n          path: quiz/submit\n          method: post\n          cors: true\n\n  getQuiz:\n    handler: handlers/quiz.get_quiz\n    events:\n      - http:\n          path: quiz\n          method: get\n          cors: true\n\n  createTrip:\n    handler: handlers/trips.create_trip\n    events:\n      - http:\n          path: trips\n          method: post\n          cors: true\n\n  listTrips:\n    handler: handlers/trips.list_trips\n    events:\n      - http:\n          path: trips\n          method: get\n          cors: true\n\n  getTrip:\n    handler: handlers/trips.get_trip\n    events:\n      - http:\n          path: trips/{trip_id}\n          method: get\n          cors: true\n\n  updateTrip:\n    handler: handlers/trips.update_trip\n    events:\n      - http:\n          path: trips/{trip_id}\n          method: put\n          cors: true\n\n  deleteTrip:\n    handler: handlers/trips.delete_trip\n    events:\n      - http:\n          path: trips/{trip_id}\n          method: delete\n          cors: true\n\n  uploadProfilePhoto:\n    handler: handlers/uploads.upload_profile_photo\n    events:\n      - http:\n          path: uploads/profile-photo\n          method: post\n          cors: true\n\n  uploadTripPhoto:\n    handler: handlers/uploads.upload_trip_photo\n    events:\n      - http:\n          path: uploads/trip-photo\n          method: post\n          cors: true\n\n  uploadPoiImage:\n    handler: handlers/uploads.upload_poi_image\n    events:\n      - http:\n          path: uploads/poi-image\n          method: post\n          cors: true\n\n  uploadItineraryPdf:\n    handler: handlers/uploads.upload_itinerary_pdf\n    events:\n      - http:\n          path: uploads/itinerary-pdf\n          method: post\n          cors: true\n\n  deleteUpload:\n    handler: handlers/uploads.delete_upload\n    events:\n      - http:\n          path: uploads\n          method: delete\n          cors: true\n\n  getProfile:\n    handler: handlers/profile.get_profile\n    events:\n      - http:\n          path: profile\n          method: get\n          cors: true\n\n  updateProfile:\n    handler: handlers/profile.update_profile\n    events:\n      - http:\n          path: profile\n          method: put\n          cors: true\n\n  getSettings:\n    handler: handlers/profile.get_settings\n    events:\n      - http:\n          path: settings\n          method: get\n          cors: true\n\n  updateSettings:\n    handler: handlers/profile.update_settings\n    events:\n      - http:\n          path: settings\n          method: put\n          cors: true\n\n  addPoiToItinerary:\n    handler: handlers/itinerary.add_poi_to_itinerary\n    events:\n      - http:\n          path: trips/{trip_id}/itinerary/pois\n          method: post\n          cors: true\n\n  removePoiFromItinerary:\n    handler: handlers/itinerary.remove_poi_from_itinerary\n    events:\n      - http:\n          path: trips/{trip_id}/itinerary/pois/{poi_id}\n          method: delete\n          cors: true\n\n  updatePoiInItinerary:\n    handler: handlers/itinerary.update_poi_in_itinerary\n    events:\n      - http:\n          path: trips/{trip_id}/itinerary/pois/{poi_id}\n          method: put\n          cors: true\n\n  reorderItinerary:\n    handler: handlers/itinerary.reorder_itinerary\n    events:\n      - http:\n          path: trips/{trip_id}/itinerary/reorder\n          method: post\n          cors: true\n\n  getTripRecommendations:\n    handler: handlers/trip_planning.get_trip_recommendations\n    events:\n      - http:\n          path: trips/{trip_id}/recommendations\n          method: get\n          cors: true\n\n  calculateTripCosts:\n    handler: handlers/trip_planning.calculate_trip_costs\n    events:\n      - http:\n          path: trips/{trip_id}/costs\n          method: get\n          cors: true\n\n  generateAiItinerary:\n    handler: handlers/ai_itinerary.generate\n    timeout: 60\n    events:\n      - http:\n          path: ai/itinerary/generate\n          method: post\n          cors: true\n\n  searchPlaces:\n    handler: handlers/location.search_places\n    events:\n      - http:\n          path: location/search\n          method: get\n          cors: true\n\ncustom:\n  pythonRequirements: {}\n\nresources:\n  Resources:\n    TripMapView:\n      Type: AWS::Location::Map\n      Properties:\n        Configuration:\n          Style: VectorEsriStreets\n        MapName: ${self:provider.environment.LOCATION_MAP_NAME}\n        Description: Map for trip visualization\n        PricingPlan: RequestBasedUsage\n\n    TripPlaceIndex:\n      Type: AWS::Location::PlaceIndex\n      Properties:\n        DataSource: Esri\n        IndexName: ${self:provider.environment.LOCATION_PLACE_INDEX_NAME}\n        Description: Place index for POI search\n        PricingPlan: RequestBasedUsage\n\n    TripRouteCalculator:\n      Type: AWS::Location::RouteCalculator\n      Properties:\n        CalculatorName: TripRouteCalculator\n        DataSource: Esri\n        Description: Route calculator for trip directions\n        PricingPlan: RequestBasedUsage\n",
    "command": [
      "deploy",
      "function"
    ],
